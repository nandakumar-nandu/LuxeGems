# 📁 Environment Variables Example Template
# ⚙️ Used to bootstrap environment variables for other developers.
# ⚠️ Copy this file to `.env` and fill in the values. Do not store secrets here!

# MongoDB Database Connection String
MONGODB_URI=""

# Stripe Secret API Key (Server-side)
# 🔒 Keep secret and do not expose to client code.
STRIPE_SECRET_KEY=""

# Stripe Webhook Endpoint Secret (Server-side validation)
# 🔒 Used to verify webhook events from Stripe.
STRIPE_WEBHOOK_SECRET=""

# Stripe Publishable Key (Client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Public URL of the Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
