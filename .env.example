# ==============================================================================
# 📁 .env.example — LuxeGems Store Environment Variables Template
# ==============================================================================
# ⚠️  SETUP INSTRUCTIONS:
#     1. Copy this file:  cp .env.example .env
#     2. Fill in every value below
#     3. NEVER commit your real .env file — it is already in .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 🗄️  MONGODB DATABASE
# Where to get it:
#   - Local: install MongoDB Community Edition from https://www.mongodb.com/try/download/community
#     Then use: mongodb://localhost:27017/luxegems
#   - Cloud (recommended): create a free cluster at https://cloud.mongodb.com
#     Then copy the connection string from Cluster → Connect → Drivers (Node.js)
# ------------------------------------------------------------------------------
MONGODB_URI="mongodb://localhost:27017/luxegems"

# ------------------------------------------------------------------------------
# 💳  STRIPE PAYMENT INTEGRATION
# Where to get these keys:
#   1. Create a free account at https://stripe.com
#   2. Go to Developers → API Keys in the Stripe Dashboard
#   3. Use TEST mode keys while developing (prefixed sk_test_ / pk_test_)
#   4. Switch to LIVE keys only in production
# ------------------------------------------------------------------------------

# Server-side secret key — NEVER expose to the browser
# Used to create Checkout Sessions and retrieve payment data
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret — used to verify that events came from Stripe
# Where to get it:
#   1. Go to Developers → Webhooks in the Stripe Dashboard
#   2. Add endpoint: https://your-domain.com/api/webhook
#   3. Select events: checkout.session.completed, payment_intent.payment_failed
#   4. Copy the "Signing secret" (whsec_...)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Client-side publishable key — safe to expose in browser code
# Identifies your Stripe account when redirecting to Checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ------------------------------------------------------------------------------
# 📧  EMAILJS — Contact Form Email Delivery
# Where to get these values:
#   1. Create a free account at https://www.emailjs.com (200 emails/month free)
#   2. Go to Email Services → Add New Service → connect Gmail or SMTP
#   3. Copy the Service ID shown on the service card
#   4. Go to Email Templates → Create New → design your inquiry email template
#   5. Copy the Template ID from the template settings
#   6. Go to Account → API Keys → copy your Public Key
# ------------------------------------------------------------------------------

# The Service ID of your connected email provider (Gmail, Outlook, SMTP etc.)
NEXT_PUBLIC_EMAILJS_SERVICE_ID="service_xxxxxxx"

# The Template ID of the email template you created
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="template_xxxxxxx"

# Your EmailJS Public API Key (safe to include in client-side code)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY="xxxxxxxxxxxxxxxx"

# ------------------------------------------------------------------------------
# 🌐  APPLICATION
# Where to set it:
#   - Development: leave as http://localhost:3000
#   - Production: set to your actual deployed domain, e.g. https://luxegems.vercel.app
#   This value is used for:
#     * Stripe success/cancel redirect URLs
#     * generateMetadata() dynamic OG image fetches
#     * Absolute URL construction in API routes
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
